# Firebase web-app config (from Firebase console → Project settings → Your apps).
# The web SDK treats these as public — they gate *which* project the client
# talks to, not *whether* it's allowed to. Authorization is enforced by the
# Cloud Run backend via the Firebase ID token.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Cloud Run prediction API base URL (no trailing slash).
# Example: https://fantasy-coach-api-xxxxxx-ts.a.run.app
VITE_API_BASE_URL=
