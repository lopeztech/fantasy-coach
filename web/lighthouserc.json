{
  "ci": {
    "collect": {
      "staticDistDir": "./dist",
      "numberOfRuns": 1,
      "settings": {
        "chromeFlags": "--no-sandbox --disable-setuid-sandbox",
        "skipAudits": [
          "canonical",
          "is-crawlable",
          "robots-txt",
          "hreflang",
          "errors-in-console",
          "meta-description"
        ]
      }
    },
    "assert": {
      "assertions": {
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:performance": ["warn", { "minScore": 0.9 }],
        "categories:best-practices": ["warn", { "minScore": 0.9 }]
      }
    }
  }
}
