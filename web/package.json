    {
      "path": "dist/assets/*.js",
      "gzip": true,
      "limit": "200 KB"
    }
  ],
  "dependencies": {
    "firebase": "^12.12.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@lhci/cli": "^0.14.0",
    "@size-limit/file": "^11.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "size-limit": "^11.0.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.11",
    "vite-plugin-pwa": "^1.2.0"
  }
}
