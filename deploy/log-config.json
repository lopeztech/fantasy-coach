{
  "version": 1,
  "disable_existing_loggers": false,
  "formatters": {
    "json": {
      "()": "fantasy_coach.logging_config.CloudRunJsonFormatter"
    }
  },
  "handlers": {
    "console": {
      "class": "logging.StreamHandler",
      "formatter": "json",
      "stream": "ext://sys.stdout"
    }
  },
  "loggers": {
    "uvicorn": {
      "handlers": ["console"],
      "level": "INFO",
      "propagate": false
    },
    "uvicorn.error": {
      "handlers": ["console"],
      "level": "INFO",
      "propagate": false
    },
    "uvicorn.access": {
      "handlers": ["console"],
      "level": "INFO",
      "propagate": false
    },
    "fantasy_coach": {
      "handlers": ["console"],
      "level": "INFO",
      "propagate": false
    }
  },
  "root": {
    "handlers": ["console"],
    "level": "INFO"
  }
}
